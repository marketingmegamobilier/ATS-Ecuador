# ============================================
# CONFIGURACIÓN DEL FRONTEND - EJEMPLO
# ============================================
# 
# INSTRUCCIONES:
# 1. Copia este archivo y renómbralo a ".env"
# 2. Modifica los valores según tu entorno
# 3. Las variables en React deben empezar con REACT_APP_
# 4. Reinicia el servidor después de modificar este archivo
#
# ============================================

# ==================
# API BACKEND
# ==================
# URL del servidor backend
# En desarrollo local:
REACT_APP_API_URL=http://localhost:8000

# En producción:
# REACT_APP_API_URL=https://api.tudominio.com

# ==================
# APLICACIÓN
# ==================
# Nombre de la aplicación
REACT_APP_NAME=Sistema ATS Ecuador

# Versión de la aplicación
REACT_APP_VERSION=1.0.0

# ==================
# CONFIGURACIONES OPCIONALES
# ==================

# Puerto del servidor de desarrollo (opcional)
# PORT=3000

# Abrir navegador automáticamente al iniciar
# BROWSER=chrome

# Desactivar apertura automática del navegador
# BROWSER=none

# ==================
# FEATURE FLAGS
# ==================
# Habilitar funcionalidades experimentales
# REACT_APP_ENABLE_ANALYTICS=false
# REACT_APP_ENABLE_DEBUG=true

# ==================
# SRI
# ==================
# Enlaces útiles del SRI (solo informativo)
# REACT_APP_SRI_URL=https://www.sri.gob.ec
# REACT_APP_DIMM_DOWNLOAD_URL=https://www.sri.gob.ec/dimm

# ==================
# CONFIGURACIÓN DE BUILD
# ==================
# Para configurar el build de producción
# GENERATE_SOURCEMAP=false
# INLINE_RUNTIME_CHUNK=false
