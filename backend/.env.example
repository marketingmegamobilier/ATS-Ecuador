# ============================================
# CONFIGURACIÓN DEL BACKEND - EJEMPLO
# ============================================
# 
# INSTRUCCIONES:
# 1. Copia este archivo y renómbralo a ".env"
# 2. Modifica los valores según tu entorno
# 3. NUNCA subas el archivo .env real a Git
#
# ============================================

# ==================
# BASE DE DATOS
# ==================
# URL de conexión a la base de datos
# Para SQLite local (por defecto):
DATABASE_URL=sqlite:///./ats.db

# Para PostgreSQL (producción):
# DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/ats_db

# Para MySQL:
# DATABASE_URL=mysql://usuario:contraseña@localhost:3306/ats_db

# ==================
# SEGURIDAD
# ==================
# Clave secreta para JWT y encriptación
# IMPORTANTE: Genera una clave única y segura
# Puedes generarla con: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=cambia_esta_clave_por_una_segura_y_aleatoria_de_minimo_32_caracteres

# ==================
# APLICACIÓN
# ==================
# Modo debug (True en desarrollo, False en producción)
DEBUG=True

# Puerto del servidor (opcional, por defecto 8000)
PORT=8000

# Host del servidor
HOST=0.0.0.0

# ==================
# CORS
# ==================
# Orígenes permitidos (separados por comas)
# En desarrollo:
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# En producción, especifica tu dominio:
# CORS_ORIGINS=https://tudominio.com,https://www.tudominio.com

# ==================
# ARCHIVOS SUBIDOS
# ==================
# Tamaño máximo de archivo en MB
MAX_FILE_SIZE=10

# Directorio para archivos temporales
UPLOAD_DIR=./uploads

# ==================
# LOGGING
# ==================
# Nivel de logs (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Archivo de logs
LOG_FILE=./logs/app.log

# ==================
# SRI (OPCIONAL)
# ==================
# Configuración para servicios del SRI (si se implementa)
# SRI_API_URL=https://cel.sri.gob.ec
# SRI_TIMEOUT=30

# ==================
# EMAIL (OPCIONAL)
# ==================
# Para envío de notificaciones por correo
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu_email@gmail.com
# SMTP_PASSWORD=tu_contraseña_de_aplicacion
# SMTP_FROM=noreply@tudominio.com
