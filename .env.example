# ============================================
# CONFIGURACION PARA DOCKER COMPOSE
# ATS Ecuador - Despliegue con Dokploy
# ============================================
#
# INSTRUCCIONES:
# 1. Copia este archivo como ".env" en la raiz del proyecto
# 2. Completa todos los valores
# 3. Dokploy leera este archivo automaticamente
#
# ============================================

# ==================
# POSTGRESQL
# ==================
POSTGRES_DB=ats_db
POSTGRES_USER=ats_user
POSTGRES_PASSWORD=genera_una_contraseña_segura_aqui

# ==================
# BACKEND
# ==================
# Clave secreta para JWT - GENERA UNA UNICA
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=genera_una_clave_secreta_aqui

# Modo debug (false en produccion)
DEBUG=false

# CORS - URLs permitidas separadas por coma
# Reemplaza tudominio.com con tu dominio real
CORS_ORIGINS=https://tudominio.com,https://www.tudominio.com

# Tamano maximo de archivo en MB
MAX_FILE_SIZE=10

# Nivel de logs
LOG_LEVEL=INFO

# ==================
# FRONTEND
# ==================
# URL del backend (la URL publica donde los usuarios acceden a la API)
# Si Dokploy asigna un dominio al backend, usa esa URL
REACT_APP_API_URL=https://api.tudominio.com
